<Window x:Class="BTAudioTray.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BTAudioTray"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="360"
        Topmost="True"
        Deactivated="OnDeactivated">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Segoe Fluent Icons glyphs -->
        <Style x:Key="Glyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#E6FFFFFF"/>
        </Style>

        <!-- Device row button: flat, hover/press highlight, rounded -->
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="6,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#14FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterButton" TargetType="Button" BasedOn="{StaticResource RowButton}">
            <Setter Property="Padding" Value="10,7"/>
        </Style>

        <DataTemplate x:Key="DeviceTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Accent bar on the default-output device -->
                <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="0,2"
                        Background="#4CC2FF"
                        Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}"/>

                <TextBlock Grid.Column="1" Style="{StaticResource Glyph}" Text="&#xE7F6;"/>
                <!-- headphones-ish glyph (EC4F headset / E7F6 audio); E7F6 = music note. -->

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="2,0,0,0">
                    <TextBlock Text="{Binding Name}" Foreground="#F2FFFFFF" FontSize="14"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="#99FFFFFF" FontSize="12" Margin="0,1,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="3" Style="{StaticResource Glyph}" Text="&#xE73E;" FontSize="16"
                           Foreground="#4CC2FF" Margin="0,0,4,0"
                           Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <!-- Card -->
    <Border CornerRadius="8" Background="#2A2A2E" Margin="12"
            BorderBrush="#22FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.45" Color="Black"/>
        </Border.Effect>

        <StackPanel Margin="0,12,0,8">
            <!-- Header -->
            <TextBlock Text="Bluetooth Audio" Foreground="#F2FFFFFF" FontSize="15" FontWeight="SemiBold"
                       Margin="18,0,18,10"/>

            <!-- Device list -->
            <ItemsControl x:Name="DeviceList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource RowButton}" Click="OnDeviceClick"
                                Content="{Binding}" ContentTemplate="{StaticResource DeviceTemplate}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock x:Name="EmptyText" Text="No Bluetooth audio devices"
                       Foreground="#99FFFFFF" FontSize="13" Margin="18,8" Visibility="Collapsed"/>

            <!-- Separator -->
            <Border Height="1" Background="#1AFFFFFF" Margin="14,8,14,6"/>

            <!-- Footer -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource FooterButton}" Click="OnRefresh">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE72C;" FontSize="15"/>
                        <TextBlock Text="Refresh" Foreground="#E6FFFFFF" FontSize="13" Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource FooterButton}" Click="OnExit">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE7E8;" FontSize="15"/>
                        <TextBlock Text="Exit" Foreground="#E6FFFFFF" FontSize="13" Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>
