<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <!-- Lower bound so it still installs/runs on older Win10/11 builds -->
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- WPF for the flyout UI; WinForms only for the NotifyIcon tray presence. -->
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <!-- No console window; single self-contained-ish exe when published -->
    <AssemblyName>BTAudioTray</AssemblyName>
    <RootNamespace>BTAudioTray</RootNamespace>
    <Version>0.1.0</Version>
    <ApplicationIcon>assets\connected.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="assets\connected.ico" />
    <EmbeddedResource Include="assets\disconnected.ico" />
  </ItemGroup>

</Project>
